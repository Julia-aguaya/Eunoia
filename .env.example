# Django core
DJANGO_SECRET_KEY=change-me-before-deploy
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000
DJANGO_USE_SQLITE=True
DJANGO_DATABASE_PATH=db.sqlite3
DJANGO_SECURE_SSL_REDIRECT=False

# Production MySQL (recommended for deploy; DATABASE_URL takes precedence)
DATABASE_URL=
DJANGO_DB_ENGINE=
DJANGO_DB_NAME=
DJANGO_DB_USER=
DJANGO_DB_PASSWORD=
DJANGO_DB_HOST=
DJANGO_DB_PORT=
DJANGO_DB_CHARSET=utf8mb4
DJANGO_DB_SQL_MODE=STRICT_TRANS_TABLES
DJANGO_DB_SSL_CA=
DJANGO_DB_SSL_CERT=
DJANGO_DB_SSL_KEY=
DJANGO_DB_CONNECT_TIMEOUT=5
DJANGO_DB_CONN_MAX_AGE=60
DJANGO_DB_CONN_HEALTH_CHECKS=True

# Eunoia ops
EUNOIA_DEFAULT_TEMPORARY_PASSWORD=EunoiaTemp2026!
EUNOIA_ADMIN_EMAIL=admin@example.com
EUNOIA_ADMIN_PASSWORD=ChangeThisAdminPassword2026!
